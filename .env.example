# Data source
TWELVE_DATA_API_KEY=
# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_TABLE=daily_stock_prices

# Pipeline scope
SYMBOLS=AAPL,GOOGL,MSFT
START_DATE=2015-01-01

# MLflow
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=volatility-nn
MLFLOW_REGISTER_MODELS=false
MLFLOW_MODEL_NAME_PREFIX=volatility-nn

# Training parameters (optional overrides)
WINDOW_SIZE=21
TRAIN_TEST_SPLIT=0.5
ROLLING_WINDOW=21
RNN_HIDDEN_SIZE=24
RNN_NUM_LAYERS=1
FC_HIDDEN_SIZE=12
DROPOUT=0.1
BATCH_SIZE=64
LEARNING_RATE=0.001
EPOCHS=20
